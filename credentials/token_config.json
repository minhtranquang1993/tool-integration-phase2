{
    "tokens": {
        "classic": {
            "env_var": "GITHUB_TOKEN_CLASSIC",
            "file_path": "credentials/github_token.txt",
            "_comment": "Personal access token (classic) — priority 1"
        },
        "fire_gains": {
            "env_var": "GITHUB_TOKEN_FIRE_GAINS",
            "file_path": "credentials/github_token_fire_gains.txt",
            "_comment": "Fallback token — priority 2"
        }
    },
    "repo_overrides": {
        "_comment": "Map specific owner/repo to preferred token alias. If credentials/github_seo_repos.json exists, it will be merged."
    }
}